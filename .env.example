# ForgeBox Development Environment
# Copy this file to .env and fill in your values

# LLM Provider API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Ollama (if running locally or in another container)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# PostgreSQL (matches docker-compose defaults)
POSTGRES_USER=forgebox
POSTGRES_PASSWORD=forgebox
POSTGRES_DB=forgebox
DATABASE_URL=postgres://forgebox:forgebox@postgres:5432/forgebox?sslmode=disable

# VM Mode: "local" for dev (no Firecracker), "firecracker" for production
FORGEBOX_VM_MODE=local

# First-install bootstrap password (required to create the initial admin account)
# Set this, then POST /api/v1/setup with setup_password to create the first user.
# FORGEBOX_FIRST_PASSWORD=
