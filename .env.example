# ForgeBox Development Environment
# Copy this file to .env and fill in your values

# LLM Provider API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Ollama (if running locally or in another container)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# PostgreSQL — the only supported storage backend (REQUIRED).
# Holds tasks, sessions, audit, users, automations, apps, providers, and
# brain (pgvector) tables in one database.
POSTGRES_USER=forgebox
POSTGRES_PASSWORD=forgebox
POSTGRES_DB=forgebox
FORGEBOX_DATABASE_URL=postgres://forgebox:forgebox@postgres:5432/forgebox?sslmode=disable

# VM Mode: "local" for dev (no Firecracker), "firecracker" for production
FORGEBOX_VM_MODE=local

# First-install bootstrap password (required to create the initial admin account)
# Set this, then POST /api/v1/setup with setup_password to create the first user.
# FORGEBOX_FIRST_PASSWORD=

# Encryption key for provider credentials stored in the DB (REQUIRED).
# 32 bytes, encoded as 64 hex chars or base64. Generate one with:
#   openssl rand -hex 32
# The server refuses to start without it. Treat as a separate secret from
# the DB itself: backing up the DB without this key produces unusable data,
# and rotating it without re-sealing existing rows breaks every DB-backed
# provider.
FORGEBOX_DB_ENCRYPTION_KEY=