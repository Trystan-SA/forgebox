{
  "name": "ForgeBox Desktop (Tauri)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "remoteUser": "vscode",

  "features": {
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "latest",
      "profile": "default"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tauri-apps.tauri-vscode",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "rust-analyzer.checkOnSave": true,
        "editor.formatOnSave": true
      }
    }
  },

  "forwardPorts": [3000],

  "portsAttributes": {
    "3000": { "label": "Tauri Dev Server", "onAutoForward": "openBrowser" }
  },

  "postCreateCommand": "npm install && cargo install tauri-cli",

  // Note: Tauri needs a display server for GUI development.
  // For headless builds, use `cargo tauri build`.
  // System libraries for Tauri are pre-installed in the Dockerfile.
  "postAttachCommand": "echo '>> Note: Tauri GUI requires a display server (X11/Wayland). For headless builds use: cargo tauri build'"
}
